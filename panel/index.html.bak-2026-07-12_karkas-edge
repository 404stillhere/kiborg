<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Киборг — пульт</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🤖</text></svg>">
<style>
  :root{
    --page:#0d0d0d; --card:#1a1a19; --card2:#222220;
    --ink:#ffffff; --ink2:#c3c2b7; --muted:#898781;
    --line:rgba(255,255,255,.10); --grid:#2c2c2a;
    --blue:#3987e5; --aqua:#199e70; --yellow:#c98500;
    --good:#0ca30c; --warn:#fab219; --crit:#d03b3b;
    --r:10px;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--page);color:var(--ink2);
       font:14px/1.5 system-ui,-apple-system,"Segoe UI",sans-serif;}
  .wrap{max-width:1180px;margin:0 auto;padding:20px 16px 60px}
  h1{color:var(--ink);font-size:22px;margin:0}
  h2{color:var(--ink);font-size:15px;margin:0 0 10px;display:flex;align-items:center;gap:8px}
  h2 .sub{color:var(--muted);font-weight:400;font-size:12px}
  a{color:var(--blue)}
  .head{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .head .upd{color:var(--muted);font-size:12px;margin-left:auto}

  .chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
  .chip{background:var(--card);border:1px solid var(--line);border-radius:999px;
        padding:5px 12px;font-size:12.5px;display:flex;align-items:center;gap:7px;color:var(--ink2)}
  .dot{width:8px;height:8px;border-radius:50%;flex:none}
  .dot.good{background:var(--good)} .dot.warn{background:var(--warn)}
  .dot.crit{background:var(--crit)} .dot.blue{background:var(--blue)}
  .dot.mut{background:var(--muted)}
  .chip b{color:var(--ink);font-weight:600}

  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media (max-width:900px){.grid2{grid-template-columns:1fr}}
  .card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);
        padding:16px;margin-bottom:14px}

  /* конвейер */
  .flow{display:flex;align-items:stretch;gap:0;flex-wrap:wrap;margin:10px 0 4px}
  .node{background:var(--card2);border:1px solid var(--line);border-radius:8px;
        padding:7px 10px;cursor:pointer;min-width:0;transition:border-color .15s}
  .node:hover{border-color:var(--blue)}
  .node.sel{border-color:var(--blue);box-shadow:0 0 0 1px var(--blue)}
  .node .nm{color:var(--ink);font-size:12.5px;font-weight:600;white-space:nowrap}
  .node .rl{font-size:10.5px;color:var(--muted)}
  .arrow{color:var(--muted);align-self:center;padding:0 6px;font-size:14px;flex:none}
  .organ-detail{background:var(--card2);border:1px solid var(--line);border-radius:8px;
        padding:10px 12px;margin-top:10px;font-size:13px;display:none}
  .organ-detail.show{display:block}
  .organ-detail .io{color:var(--muted);font-size:12px;margin-top:4px}
  .kv{color:var(--ink);font-weight:600}

  button{font:inherit;border-radius:8px;border:1px solid var(--line);cursor:pointer;
         background:var(--card2);color:var(--ink);padding:7px 14px}
  button:hover{border-color:var(--blue)}
  button:disabled{opacity:.45;cursor:default}
  button.run{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:600}
  button.run:disabled{background:var(--card2);border-color:var(--line);color:var(--muted)}
  button.mini{padding:4px 10px;font-size:12.5px}
  button.take{border-color:var(--good);color:var(--good)}
  button.take:hover{background:rgba(12,163,12,.12)}
  button.later{color:var(--ink2)}
  button.trash{border-color:var(--crit);color:var(--crit)}
  button.trash:hover{background:rgba(208,59,59,.12)}

  /* консоль прогона */
  .console{background:#0a0a0a;border:1px solid var(--grid);border-radius:8px;
           font:12px/1.55 ui-monospace,Consolas,monospace;color:var(--ink2);
           padding:12px;max-height:320px;overflow:auto;white-space:pre-wrap;word-break:break-word}
  .console:empty::before{content:"тут появится живой вывод, когда запустишь прогон";color:var(--muted)}
  .runstate{font-size:12px;color:var(--muted);margin-top:6px}
  .spin{display:inline-block;animation:sp 1s linear infinite}
  @keyframes sp{to{transform:rotate(360deg)}}

  /* инбокс */
  .idea{background:var(--card2);border:1px solid var(--line);border-radius:8px;
        padding:12px;margin-bottom:10px}
  .idea .t{color:var(--ink);font-weight:600;margin-bottom:4px}
  .idea .w{font-size:13px;color:var(--ink2)}
  .idea .meta{display:flex;gap:6px;flex-wrap:wrap;margin:8px 0 0}
  .tag{font-size:11px;border:1px solid var(--line);border-radius:999px;padding:1px 8px;color:var(--muted)}
  .tag.llm{border-color:var(--blue);color:var(--blue)}
  .idea .acts{display:flex;gap:8px;margin-top:10px}
  .done-row{padding:6px 10px;border-bottom:1px solid var(--grid);font-size:13px;display:flex;gap:8px}
  .done-row:last-child{border-bottom:0}
  .st{font-size:11px;border-radius:999px;padding:1px 8px;flex:none;align-self:center}
  .st.take{background:rgba(12,163,12,.15);color:var(--good)}
  .st.later{background:rgba(250,178,25,.12);color:var(--warn)}
  .st.trash{background:rgba(208,59,59,.14);color:var(--crit)}
  .finish-card{border-left:3px solid var(--aqua)}
  .capbar{display:flex;gap:4px;margin:2px 0 12px}
  .capbar .slot{height:8px;flex:1;border-radius:4px;background:var(--grid)}
  .capbar .slot.full{background:var(--yellow)}

  /* журнал */
  .runrow{padding:8px 0;border-bottom:1px solid var(--grid);font-size:13px}
  .runrow:last-child{border-bottom:0}
  .runrow .ts{color:var(--muted);font-size:11.5px}
  .runrow .chain{color:var(--muted);font-size:12px}
  .runrow .chain b{color:var(--ink2);font-weight:500}
  .runrow .res{font-size:12px}
  .res .okv{color:var(--good)} .res .zero{color:var(--muted)}

  /* реестр */
  .strip{display:flex;gap:2px;height:14px;border-radius:7px;overflow:hidden;margin:8px 0 6px}
  .strip div{min-width:3px}
  .legend{display:flex;gap:14px;font-size:12px;color:var(--ink2);flex-wrap:wrap}
  .legend .dot{width:9px;height:9px;display:inline-block;margin-right:5px;border-radius:50%}
  .pbars{margin-top:12px}
  .pbar{display:grid;grid-template-columns:170px 1fr 30px;gap:8px;align-items:center;
        font-size:12px;margin-bottom:4px}
  .pbar .nm{color:var(--ink2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-align:right}
  .pbar .bar{height:9px;border-radius:4px;background:var(--blue);min-width:2px}
  .pbar .n{color:var(--muted)}
  input[type=search]{background:var(--card2);border:1px solid var(--line);color:var(--ink);
        border-radius:8px;padding:7px 12px;width:100%;font:inherit;margin:10px 0}
  input[type=search]:focus{outline:none;border-color:var(--blue)}
  .reg-list{max-height:340px;overflow:auto}
  .reg-row{padding:7px 4px;border-bottom:1px solid var(--grid);font-size:12.5px}
  .reg-row:last-child{border-bottom:0}
  .reg-row .nm{color:var(--ink);font-weight:600}
  .reg-row .pj{color:var(--muted)}
  .reg-row .pp{color:var(--ink2);margin-top:2px}
  .reg-row .keys{color:var(--warn);font-size:11px}
  details summary{cursor:pointer;color:var(--muted);font-size:13px;user-select:none}
  details[open] summary{margin-bottom:8px}

  /* каркас киборга */
  .skel-grid{display:grid;grid-template-columns:minmax(320px,620px) 1fr;gap:20px;align-items:start}
  @media (max-width:900px){.skel-grid{grid-template-columns:1fr}}
  #skel{max-width:620px;margin:0 auto}
  #skel svg{width:100%;height:auto;display:block;touch-action:none;user-select:none}
  #skel .draggable{cursor:grab}
  #skel .draggable:active{cursor:grabbing}
  #skel .slot-hint{fill:none;stroke:#3d3d36;stroke-width:1.5;stroke-dasharray:4 4}
  #skel .bone{stroke:var(--grid);stroke-width:5;fill:none;stroke-linecap:round}
  #skel .plate{fill:#161615;stroke:#34342f;stroke-width:1.5}
  #skel .spinebone{stroke:#3d3d38;stroke-width:5;stroke-dasharray:7 6;fill:none}
  #skel .nerve{stroke:#2e2e2b;stroke-width:1.2;stroke-dasharray:2 4;fill:none}
  #skel .organ{cursor:pointer}
  #skel .organ .nodebg{fill:#222220;stroke-width:2;transition:stroke-width .15s}
  #skel .organ:hover .nodebg{stroke-width:3.5}
  #skel .organ.sel .nodebg{stroke-width:4}
  #skel .organ.work .nodebg{stroke:var(--warn) !important;stroke-width:4;animation:pulse 1s infinite}
  #skel .builtin .ring{fill:transparent;stroke-width:2;stroke-dasharray:3 4;opacity:.65;transition:opacity .15s}
  #skel .builtin:hover .ring{opacity:1;stroke-dasharray:none}
  #skel .builtin.sel .ring{opacity:1;stroke-dasharray:none;stroke-width:3.5}
  #skel .builtin.work .ring{stroke:var(--warn) !important;opacity:1;stroke-dasharray:none;animation:pulse 1s infinite}
  @keyframes pulse{0%,100%{stroke-opacity:1}50%{stroke-opacity:.3}}
  #skel .lbl{font-size:10.5px;fill:var(--muted)}
  #skel .leader{stroke:#3a3a36;stroke-width:1;fill:none}
  #skel .eye{fill:#3a3a36}
  #skel .organ.sel .eye,#skel .organ:hover .eye{fill:var(--aqua)}

  /* оживление рыцаря: дыхание · пульс сердца · живые нервы */
  #skel .breath{transform-box:fill-box;transform-origin:50% 100%;
        animation:breathe 4.2s ease-in-out infinite}
  #skel svg.running .breath{animation-play-state:paused}
  @keyframes breathe{0%,100%{transform:translateY(0) scaleY(1)}
        50%{transform:translateY(-2.4px) scaleY(1.014)}}
  @media (prefers-reduced-motion:reduce){#skel .breath,#skel .heartbeat,#skel .nerve{animation:none}}

  /* сердце-ромб: два толчка (систола-диастола), темп задаёт заполненность инбокса (--hb) */
  #skel .heartbeat{fill:#e6484d;opacity:0;transform-box:fill-box;transform-origin:center;
        pointer-events:none;animation:hb var(--hb,1.4s) ease-in-out infinite;
        filter:drop-shadow(0 0 5px rgba(230,72,77,.7))}
  @keyframes hb{
        0%{transform:scale(.70);opacity:.14}
        13%{transform:scale(1.14);opacity:.52}
        26%{transform:scale(.88);opacity:.30}
        40%{transform:scale(1.03);opacity:.44}
        60%,100%{transform:scale(.70);opacity:.12}}
  #skel .heartbeat.full{filter:drop-shadow(0 0 9px rgba(230,72,77,.9))}

  /* нервы: тихий ток в простое, разгон и подсветка при прогоне */
  #skel .nerve{animation:nflow 3s linear infinite}
  @keyframes nflow{to{stroke-dashoffset:-18}}
  #skel svg.running .nerve{stroke:var(--warn);stroke-opacity:.85;stroke-width:1.6;animation-duration:.7s}
  .part-detail{background:var(--card2);border:1px solid var(--line);border-radius:8px;
        padding:14px;font-size:13.5px;min-height:120px}
  .part-detail .pt{color:var(--ink);font-weight:700;font-size:15px;margin-bottom:6px}
  .part-detail .io{color:var(--muted);font-size:12px;margin:8px 0}
  .part-detail .hint{color:var(--muted)}
  .skel-caption{color:var(--muted);font-size:11.5px;margin-top:8px}
  .bodypick{margin-top:10px;display:flex;gap:6px;align-items:center;flex-wrap:wrap}
  .bodypick .lbl2{color:var(--muted);font-size:12px;margin-right:2px}
  .bstyle.on{border-color:var(--blue);background:rgba(57,135,229,.15);color:var(--ink)}

  /* силуэты будущих органов (куда растёт киборг) */
  .future{margin-top:14px}
  .future .lbl2{color:var(--ink2);font-size:12.5px}
  .ghost{display:inline-flex;align-items:center;gap:6px;background:transparent;
        border:1.5px dashed #3d3d36;border-radius:999px;padding:4px 11px;margin:0 6px 6px 0;
        font-size:12px;color:var(--muted);cursor:pointer;transition:border-color .15s,color .15s}
  .ghost:hover{border-color:var(--aqua);color:var(--ink2)}
  .ghost.on{border-style:solid;border-color:var(--aqua);color:var(--ink)}
  .ghost .gi{opacity:.75}

  /* гейты */
  .gate{display:flex;gap:10px;padding:10px 12px;border:1px solid var(--line);
        border-radius:8px;margin-bottom:8px;background:var(--card2);font-size:13px;align-items:baseline}
  .gate .ic{flex:none}
  .gate b{color:var(--ink)}
  .foot{color:var(--muted);font-size:11.5px;margin-top:24px;text-align:center}
  .err{color:var(--crit);font-size:12px}
</style>
</head>
<body>
<div class="wrap">

  <div class="head">
    <h1>🤖 Киборг — пульт</h1>
    <span class="upd" id="upd">загружаю…</span>
  </div>

  <div class="card">
    <h2>Каркас <span class="sub">ткни в орган — расскажу, что делает, и дам задействовать</span></h2>
    <div class="skel-grid">
      <div id="skel"></div>
      <div>
        <div class="part-detail" id="part-detail"><span class="hint">Собери киборга: перетащи органы из лотка на тело. Клик по органу — что делает и кнопка задействовать.</span></div>
        <div class="skel-caption">Пунктирные кружки — подсказки мест (магнитятся) · тащить можно куда угодно · назад в лоток — просто утащи вправо.<br>
        🟡 жёлтая вспышка — орган отработал в прогоне · сердце, лоб и позвоночник — встроенные, их не подвинуть.</div>
        <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap">
          <button class="mini" onclick="layoutHint()">✨ Подсказать расстановку</button>
          <button class="mini" onclick="layoutClear()">↺ Всё в лоток</button>
        </div>
        <div class="bodypick" id="bodypick">
          <span class="lbl2">облик рыцаря:</span>
          <button class="mini bstyle" data-style="metal" onclick="setBody('metal')">⚔ Металл</button>
          <button class="mini bstyle" data-style="flat" onclick="setBody('flat')">🛡 Плоский</button>
          <button class="mini bstyle" data-style="poly" onclick="setBody('poly')">💠 Грани</button>
        </div>
        <div class="future" id="future-wrap">
          <div class="lbl2" style="width:100%;margin-bottom:4px">🌱 куда растёт
            <span style="color:var(--muted);font-weight:400">— силуэты будущих органов из каталога, кликни</span></div>
          <div id="future-organs"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="chips" id="chips"></div>

  <div class="grid2">
    <div class="card">
      <h2>Работа 1: приносить идеи <span class="sub">конвейер органов</span></h2>
      <div style="font-size:13px">Сходить за свежими новостями → придумать 6 идей → судья отберёт 3 лучшие → вычистить секреты → положить в инбокс.</div>
      <div class="flow" id="flow-ideas"></div>
      <div style="margin-top:12px"><button class="run" id="btn-ideas" onclick="runGoal('приноси свежие идеи')">▶ Принеси идеи</button></div>
    </div>
    <div class="card">
      <h2>Работа 2: доделывать проекты <span class="sub">когда инбокс полон</span></h2>
      <div style="font-size:13px">Достать «самый маленький шаг доделать» из карты твоих проектов (с ротацией) и положить в отдельный слот инбокса.</div>
      <div class="flow" id="flow-finish"></div>
      <div style="margin-top:12px"><button class="run" id="btn-finish" onclick="runGoal('доделать существующие проекты')">▶ Шаг «доделать»</button></div>
    </div>
  </div>
  <div class="organ-detail" id="organ-detail"></div>

  <div class="card">
    <h2>Прогон вживую <span class="sub">что киборг делает прямо сейчас</span></h2>
    <div class="console" id="console"></div>
    <div class="runstate" id="runstate"></div>
  </div>

  <div class="card">
    <h2>🗃 Копилка идей <span class="sub" id="stash-sub">автономный сбор — без потолка, разбирай не спеша</span></h2>
    <div style="font-size:12.5px;color:var(--muted);margin-bottom:10px">Когда киборга гоняют без тебя (я в автономном режиме), новые идеи копятся сюда горой — потолка 3 тут нет. Дедуп не даёт повторов.</div>
    <div style="margin-bottom:12px"><button class="mini" id="btn-harvest" onclick="harvest()">🌾 Собрать в копилку сейчас</button>
      <span class="sub" style="margin-left:6px">тянет свежие заголовки (топ-30 HN) и кладёт идеи в копилку; дедуп отсеет повторы</span></div>
    <div id="stash-list"></div>
  </div>

  <div class="grid2">
    <div class="card">
      <h2>Инбокс идей <span class="sub" id="inbox-sub"></span></h2>
      <div class="capbar" id="capbar"></div>
      <div id="ideas-open"></div>
      <div id="finish-slot"></div>
      <details id="done-wrap"><summary id="done-sum"></summary><div id="ideas-done"></div></details>
      <div class="err" id="inbox-err"></div>
    </div>

    <div class="card">
      <h2>Журнал прогонов <span class="sub">runs.md, свежие сверху</span></h2>
      <div id="runs" style="max-height:520px;overflow:auto"></div>
    </div>
  </div>

  <div class="card">
    <h2>Каталог органов <span class="sub" id="reg-sub">запас на рост — карточки из других проектов</span></h2>
    <div class="strip" id="reg-strip"></div>
    <div class="legend" id="reg-legend"></div>
    <div class="pbars" id="reg-projects"></div>
    <details style="margin-top:12px"><summary>Смотреть все карточки</summary>
      <input type="search" id="reg-search" placeholder="поиск: имя, проект, что делает…" oninput="renderRegList()">
      <div class="reg-list" id="reg-list"></div>
    </details>
  </div>

  <div class="card">
    <h2>Ждёт твоего решения</h2>
    <div id="gates"></div>
  </div>

  <div class="foot">Пульт только показывает и умеет две команды, что и так есть в CLI (разбор идей, запуск прогона).<br>
  Ничего в коде киборга не меняет. 127.0.0.1:8737 · обновляется сам каждые 5 сек.</div>
</div>

<script src="/bodies.js"></script>
<script>
let S = null;          // последнее состояние /api/state
let selOrgan = null;   // выбранный орган (детали)
let runPolling = false;
let running = false;    // идёт ли прогон (гоняет нервы/дыхание на каркасе)
let bodyStyle = localStorage.getItem("kbodyStyle") || "metal";  // облик рыцаря

function setBody(s){
  if(!(window.KNIGHT_BODIES && KNIGHT_BODIES[s])) return;
  bodyStyle = s;
  localStorage.setItem("kbodyStyle", s);
  document.querySelectorAll(".bstyle").forEach(b=>b.classList.toggle("on", b.dataset.style===s));
  renderSkeleton();
}

const esc = s => String(s ?? "").replace(/[&<>"']/g,
  c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));

const ROLE_RU = {source:"источник", transform:"преобразует", sink:"доставка"};
const STATUS_RU = {extracted:"готов", draft:"набросок", candidate:"кандидат"};
const STATUS_COLOR = {extracted:"var(--blue)", draft:"var(--aqua)", candidate:"var(--yellow)"};
const IDEA_ST = {take:"взял", later:"позже", trash:"мусор"};

/* --- конвейеры: цепочка от источника по produces→consumes --- */
function chainFrom(sourceName){
  const byName = Object.fromEntries(S.organs.map(o=>[o.name,o]));
  const chain = [];
  let cur = byName[sourceName];
  const seen = new Set();
  while(cur && !seen.has(cur.name)){
    chain.push(cur); seen.add(cur.name);
    const next = S.organs.find(o => !seen.has(o.name) &&
      o.consumes.some(k => cur.produces.includes(k)));
    cur = next;
  }
  return chain;
}

function renderFlow(elId, chain){
  const el = document.getElementById(elId);
  el.innerHTML = chain.map((o,i)=>
    (i? '<span class="arrow">→</span>':'') +
    `<div class="node ${selOrgan===o.name?'sel':''}" onclick="showOrgan('${esc(o.name)}')">
       <div class="nm">${esc(o.name)}</div><div class="rl">${ROLE_RU[o.role]||esc(o.role)}</div>
     </div>`).join("");
}

// пример вывода органа: реальный артефакт из живого состояния, где есть; иначе — помеченный пример
function organExample(name){
  const open = S.inbox.ideas.filter(i=>i.status==="open");
  const sIdea = open.slice(-1)[0]
