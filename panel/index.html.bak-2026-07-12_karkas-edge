function renderInbox(){
  const ib = S.inbox;
  document.getElementById("inbox-err").textContent = ib.error ? "state.json не читается: "+ib.error : "";
  const open = ib.ideas.filter(i=>i.status==="open");
  const done = ib.ideas.filter(i=>i.status!=="open").slice().reverse();
  document.getElementById("inbox-sub").textContent =
    open.length ? "разбери — иначе новые идеи не придут" : "пусто — следующий прогон принесёт новые";
  document.getElementById("capbar").innerHTML =
    Array.from({length: ib.cap}, (_,k)=>`<div class="slot ${k<open.length?'full':''}"></div>`).join("");
  document.getElementById("ideas-open").innerHTML =
    open.length ? open.map(ideaCard).join("") : `<div style="color:var(--muted);font-size:13px;margin-bottom:10px">открытых идей нет</div>`;

  const f = ib.finish;
  document.getElementById("finish-slot").innerHTML = f ? `
    <div class="idea finish-card">
      <div class="t">🔧 ${esc(f.title)}</div>
      <div class="w">${esc(f.why)}</div>
      <div class="meta"><span class="tag">слот «доделать» (дорожка B)</span>
      <span class="tag">проект: ${esc(f.folder||"?")}</span></div>
    </div>` : "";

  document.getElementById("done-sum").textContent = `разобранные (${done.length})`;
  document.getElementById("done-wrap").style.display = done.length? "block":"none";
  document.getElementById("ideas-done").innerHTML = done.map(i=>
    `<div class="done-row"><span class="st ${esc(i.status)}">${IDEA_ST[i.status]||esc(i.status)}</span>
     <span>${esc(i.title)}</span></div>`).join("");
}

async function ideaAct(id, status){
  const r = await fetch("/api/idea", {method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({id, status})}).then(r=>r.json()).catch(()=>({ok:false,msg:"сеть"}));
  if(!r.ok) alert("не вышло: " + (r.msg||""));
  refresh();
}

/* --- журнал --- */
function renderRuns(){
  const el = document.getElementById("runs");
  if(!S.runs.length){ el.innerHTML = '<div style="color:var(--muted)">прогонов ещё не было</div>'; return; }
  el.innerHTML = S.runs.slice().reverse().map(r=>{
    const v = r.value === "0" ? '<span class="zero">доставлено: 0 (ничего не добавилось)</span>'
      : /^\d+$/.test(r.value) ? `<span class="okv">доставлено: ${esc(r.value)}</span>`
      : esc(r.value);
    return `<div class="runrow">
      <div class="ts">${esc(r.ts)}</div>
      <div><b style="color:var(--ink)">«${esc(r.goal)}»</b></div>
      <div class="chain">${r.chain.map(c=>`<b>${esc(c)}</b>`).join(" → ")}</div>
      <div class="res">${esc(r.deliverable)}: ${v}</div>
    </div>`;
  }).join("");
}

/* --- копилка --- */
function renderStash(){
  const st = S.stash || {total:0, latest:[]};
  document.getElementById("stash-sub").textContent =
    st.total ? `${st.total} идей накоплено · показаны свежие` : "пока пусто — соберётся в автономных прогонах";
  const el = document.getElementById("stash-list");
  if(!st.latest.length){ el.innerHTML = '<div style="color:var(--muted);font-size:13px">копилка пуста</div>'; return; }
  el.innerHTML = st.latest.map(i=>`<div class="idea">
    ${ideaBody(i, i.brain==='llm'?'★ придумано ИИ':'болванка',
               i.stashed_at?`<span class="tag">${esc(i.stashed_at)}</span>`:"")}
  </div>`).join("");
}

/* --- реестр --- */
function renderRegistry(){
  const rg = S.registry;
  document.getElementById("reg-sub").textContent =
    `${rg.total} карточек из ${Object.keys(rg.by_project).length} проектов; киборг исполняет ${S.organs.length}`;
  const order = ["extracted","draft","candidate"];
  const strip = document.getElementById("reg-strip");
  strip.innerHTML = order.filter(s=>rg.by_status[s]).map(s=>
    `<div style="flex:${rg.by_status[s]};background:${STATUS_COLOR[s]}"></div>`).join("");
  document.getElementById("reg-legend").innerHTML = order.filter(s=>rg.by_status[s]).map(s=>
    `<span><span class="dot" style="background:${STATUS_COLOR[s]}"></span>${STATUS_RU[s]} — ${rg.by_status[s]}</span>`).join("");
  const prj = Object.entries(rg.by_project).sort((a,b)=>b[1]-a[1]);
  const mx = Math.max(...prj.map(p=>p[1]), 1);
  document.getElementById("reg-projects").innerHTML = prj.map(([p,n])=>
    `<div class="pbar"><div class="nm" title="${esc(p)}">${esc(p)}</div>
     <div><div class="bar" style="width:${Math.max(100*n/mx,2)}%"></div></div>
     <div class="n">${n}</div></div>`).join("");
  renderRegList();
}

function renderRegList(){
  const q = (document.getElementById("reg-search").value||"").toLowerCase();
  const rows = S.registry.cards.filter(c =>
    !q || [c.name,c.project,c.purpose].join(" ").toLowerCase().includes(q));
  document.getElementById("reg-list").innerHTML = rows.slice(0,200).map(c=>
    `<div class="reg-row">
       <span class="nm">${esc(c.name)}</span>
       <span class="tag" style="border-color:${STATUS_COLOR[c.status]||'var(--line)'};color:${STATUS_COLOR[c.status]||'var(--muted)'}">${STATUS_RU[c.status]||esc(c.status)}</span>
       <span class="pj"> · ${esc(c.project)}${c.language? " · "+esc(c.language):""}</span>
       <div class="pp">${esc(c.purpose)}</div>
       ${c.needs_keys.length? `<div class="keys">нужны ключи: ${esc(c.needs_keys.join(", "))}</div>`:""}
     </div>`).join("") || '<div style="color:var(--muted);padding:8px">ничего не нашлось</div>';
}

/* --- гейты --- */
function renderGates(){
  const g = [];
  const openN = S.inbox.ideas.filter(i=>i.status==="open").length;
  if(!S.key.present)
    g.push(`<div class="gate"><span class="ic">🔴</span><div><b>Ключа Gemini нет.</b> Киборг не сломается, но идеи станут шаблонными — и никакого предупреждения не будет. Верни файл gemini.md или задай GEMINI_KEY.</div></div>`);
  if(openN >= S.inbox.cap)
    g.push(`<div class="gate"><span class="ic">🟡</span><div><b>Инбокс полон (${openN}/${S.inbox.cap}).</b> Новые идеи не придут, пока не разберёшь карточки кнопками выше.</div></div>`);
  if(S.lab.exists && S.lab.locked){
    const fl = S.lab.features.map(f=>`«${esc(f.title)}»`).join(" и ");
    g.push(`<div class="gate"><span class="ic">🟡</span><div><b>Фабрика фич под замком.</b> В песочнице .feature-lab лежит неразобранный пакет: ${fl}${S.lab.needs_manual? ` + ${S.lab.needs_manual} предложение(й) руками`:""}. Пока не разберёшь (пометить reviewed или удалить router.json) — ночная фабрика новый пакет не строит.</div></div>`);
  }
  g.push(`<div class="gate"><span class="ic">⚪</span><div><b>Доставка только в файл.</b> Идеи падают в inbox.md, в Телеграм киборг писать пока не умеет — нужен токен твоего бота.</div></div>`);
  g.push(`<div class="gate"><span class="ic">⚪</span><div><b>Сам не просыпается.</b> Прогон запускается только руками (кнопки выше или CLI). Автоцикл по расписанию — твоё решение.</div></div>`);
  g.push(`<div class="gate"><span class="ic">⚪</span><div><b>Если интернет лежит</b> — киборг подставляет 4 запасных заголовка и идеи выходят «из резерва», а выглядят как свежие. Решить: глушить, помечать или оставить.</div></div>`);
  document.getElementById("gates").innerHTML = g.join("");
}

/* --- прогон --- */
async function runGoal(goal){
  const r = await fetch("/api/run", {method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({goal})}).then(r=>r.json()).catch(()=>({ok:false,msg:"сеть"}));
  if(!r.ok && r.msg) alert(r.msg);
  if(r.ok) replayed = false;   // после финиша проиграть трассу на каркасе
  pollRun();
}

async function harvest(){
  const r = await fetch("/api/harvest",{method:"POST",headers:{"Content-Type":"application/json"},body:"{}"})
    .then(r=>r.json()).catch(()=>({ok:false,msg:"сеть"}));
  if(!r.ok && r.msg) alert(r.msg);
  pollRun();   // тот же живой вывод + refresh в конце перечитает копилку
}

let replayed = true;   // повтор трассы уже проигран (не проигрывать старый прогон при открытии страницы)

async function pollRun(){
  if(runPolling) return; runPolling = true;
  const cons = document.getElementById("console");
  const st = document.getElementById("runstate");
  const btns = [document.getElementById("btn-ideas"), document.getElementById("btn-finish"),
                document.getElementById("btn-harvest")].filter(Boolean);
  try{
    while(true){
      const r = await fetch("/api/run").then(r=>r.json());
      cons.textContent = (r.lines||[]).join("\n");
      cons.scrollTop = cons.scrollHeight;
      if(!!r.running !== running){ running = !!r.running; renderSkeleton(); }  // нервы/дыхание
      // живая подсветка на каркасе: последний отработавший орган из трассы
      const hits = [...(r.lines||[]).join("\n").matchAll(/шаг \d+: ([a-z_]+)/g)];
      const cur = r.running && hits.length ? hits[hits.length-1][1] : null;
      if(cur !== workOrgan){ workOrgan = cur; renderSkeleton(); }
      if(r.running){
        btns.forEach(b=>b.disabled=true);
        st.innerHTML = `<span class="spin">⚙</span> работает: «${esc(r.goal)}»…`;
        await new Promise(res=>setTimeout(res,900));
      } else {
        btns.forEach(b=>b.disabled=false);
        // повтор на каркасе: киборг печатает трассу в конце разом, поэтому
        // проигрываем цепочку по шагам — как органы реально отработали
        if(hits.length && !replayed){
          replayed = true;
          for(const h of hits){
            workOrgan = h[1]; renderSkeleton();
            await new Promise(res=>setTimeout(res,650));
          }
        }
        if(workOrgan){ workOrgan = null; renderSkeleton(); }
        if(r.goal) st.textContent = r.rc===0
          ? `готово: «${r.goal}» (без ошибок)` : r.rc==null ? "" : `завершился с кодом ${r.rc}`;
        break;
      }
    }
  } catch(e){
    st.textContent = "пульт потерял сервер: "+e;
    btns.forEach(b=>b.disabled=false);   // не оставляем кнопки залипшими
  }
  runPolling = false;
  refresh();
}

/* --- главный цикл --- */
async function refresh(){
  try{
    S = await fetch("/api/state").then(r=>r.json());
    if(S.error) throw new Error(S.error);
    document.getElementById("upd").textContent = "обновлено " + S.now;
    if(!drag) LAYOUT = S.layout || {};
    renderSkeleton(); renderPartDetail(); renderFuture(); renderChips(); renderFlows(); renderInbox(); renderStash(); renderRuns(); renderRegistry(); renderGates();
  } catch(e){
    document.getElementById("upd").innerHTML = `<span class="err">сервер молчит: ${esc(e.message||e)}</span>`;
  }
}

document.querySelectorAll(".bstyle").forEach(b=>b.classList.toggle("on", b.dataset.style===bodyStyle));
refresh();
pollRun();               // вдруг прогон уже шёл, когда открыли страницу
setInterval(refresh, 5000);
</script>
