function svgPt(svg,e){
  const pt = new DOMPoint(e.clientX, e.clientY);
  return pt.matrixTransform(svg.getScreenCTM().inverse());
}

async function saveLayout(){
  await fetch("/api/layout",{method:"POST",headers:{"Content-Type":"application/json"},
    body:JSON.stringify({layout:LAYOUT})}).catch(()=>{});
}

function layoutHint(){   // моя анатомия как отправная точка — дальше двигай сам
  LAYOUT = {};
  ORGAN_ORDER.forEach(n=>LAYOUT[n]={x:PARTS[n].x, y:PARTS[n].y});
  renderSkeleton(); saveLayout();
}
function layoutClear(){ LAYOUT = {}; renderSkeleton(); saveLayout(); }

document.getElementById("skel").addEventListener("pointerdown", e=>{
  const g = e.target.closest(".draggable"); if(!g) return;
  const svg = g.ownerSVGElement;
  const id = g.dataset.id;
  const cur = LAYOUT[id] || trayPos(ORGAN_ORDER.indexOf(id));
  const p = svgPt(svg, e);
  drag = {id, g, svg, offX:cur.x-p.x, offY:cur.y-p.y, sx:cur.x, sy:cur.y, cx:cur.x, cy:cur.y, moved:false};
  try{ g.setPointerCapture(e.pointerId); }catch(_){}
  e.preventDefault();
});
document.addEventListener("pointermove", e=>{
  if(!drag) return;
  const p = svgPt(drag.svg, e);
  const nx = p.x+drag.offX, ny = p.y+drag.offY;
  if(!drag.moved && Math.hypot(nx-drag.sx, ny-drag.sy) < 5) return;
  drag.moved = true; drag.cx = nx; drag.cy = ny;
  drag.g.setAttribute("transform", `translate(${nx},${ny})`);
});
document.addEventListener("pointerup", e=>{
  const d = drag; if(!d) return; drag = null;
  if(!d.moved){ showPart(d.id); return; }   // это был клик, не перенос
  let x = d.cx, y = d.cy;
  if(x > TRAY_X){ delete LAYOUT[d.id]; }    // вернул в лоток
  else{
    const key = v=>Math.round(v.x)+","+Math.round(v.y);
    const taken = new Set(Object.entries(LAYOUT).filter(([k])=>k!==d.id).map(([,v])=>key(v)));
    for(const s of SLOTS){                   // магнит к свободной подсказке рядом
      if(!taken.has(key(s)) && Math.hypot(s.x-x, s.y-y) < 28){ x=s.x; y=s.y; break; }
    }
    LAYOUT[d.id] = {x:Math.round(Math.min(Math.max(x,26),440)), y:Math.round(Math.min(Math.max(y,26),512))};
  }
  renderSkeleton();
  saveLayout();
});

