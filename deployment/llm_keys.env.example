# llm_keys.env.example — шаблон конфигурации LLM ключей
#
# Скопируйте этот файл в корень проекта под именем `llm_keys.env`:
#   cp deployment/llm_keys.env.example llm_keys.env
#
# Затем вставьте реальные ключи (YOUR_KEY_HERE → ваш ключ).
# Файл llm_keys.env должен быть в .gitignore и НЕ коммититься в репо.
#
# == ВАЖНО ==
# - Ключи берутся из этого файла ENV-стилем: KEY=value (без пробелов вокруг =)
# - Пустые строки и строки с # (комментарии) игнорируются
# - Если ключа нет, соответствующий провайдер не будет использоваться
# ==


# == INTUITION CHAIN (ask_llm) ==
# Ключ для closerouter.dev (главная цепочка генерации идей)
# Используется в ask_llm.py → keychain._SPEC
# 3 модели: muse-spark → deepseek-v4-pro → nemotron-3-ultra
CLOSEROUTER_API_KEY=YOUR_CLOSEROUTER_KEY_HERE


# == COUNCIL / ORCHESTRA (advisors.py) ==
# Ключи для совета/судьи (7 моделей в orchestra)
# Эти ключи использует внешний organ.js / organ.py (не ask_llm)
# Используются только при KIBORG_SLEEP_ORCHESTRA НЕ задано (по умолчанию)

SAMBANOVA_API_KEY=YOUR_SAMBANOVA_KEY_HERE
CEREBRAS_API_KEY=YOUR_CEREBRAS_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
COHERE_API_KEY=YOUR_COHERE_KEY_HERE
MISTRAL_API_KEY=YOUR_MISTRAL_KEY_HERE
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
NVIDIA_API_KEY=YOUR_NVIDIA_KEY_HERE


# == PAID PROVIDERS (опционально) ==
# Платные API — обычно не нужны в dev-режиме (stub работает без них)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE


# == PATH OVERRIDES (опционально) ==
# Переопределение путей к внешним модулям (organ.js, organ.py, node binary)
# Обычно не нужны — используются дефолтные пути из advisors.py / ask_llm.py

# KIBORG_LLM_KEYS=/path/to/your/custom/llm_keys.env  # путь к этому файлу (дефолт: ./llm_keys.env)
# KIBORG_ASK_LLM_JS=/path/to/custom/organ.js           # путь к organ.js для ask_llm
# KIBORG_ORCHESTRA_PY=/path/to/custom/organ.py         # путь к organ.py для council
# KIBORG_NODE_EXE=/path/to/custom/node                 # путь к Node.js бинарнику
