"""Орган-приёмник finish_sink: доводит nudge из режима «доделать» до инбокса,
кладя его в ДОРОЖКУ B (store.set_finish) — отдельный слот-напоминание «доделать
существующее», который НЕ давит на потолок дорожки A (новые идеи, cap-3).

Две правки относительно кандидата песочницы feat-3 (обе по вердикту скептика):
  1. АДРЕС. feat-3 клал nudge в дорожку A через deliver.run -> store.add_idea,
     из-за чего «доделай» съедал слот новых идей и попадал в секцию «новые идеи».
     Здесь nudge идёт в дорожку B (set_finish) — как и задумано в idea_engine.
  2. ВЫЧИСТКА. nudge берёт текст из recon.next_step, где по проектам встречаются
     токены/ключи открытым текстом. Прогоняем title/why через scrub_secrets ДО
     записи — ни sk-/ghp-/AWS/bearer/KEY=, ни сырой TG-бот-токен (<id>:<auth>)
     не утекут в state.json / inbox.md.

Закрывает pair_gap: finish_step produces=["nudge"], но nudge никто не потреблял;
теперь brain._terminal("nudge") == "delivered".
Store и рендер инбокса ПЕРЕИСПОЛЬЗУЮТСЯ из idea_engine (importlib по абс-пути,
чтобы не столкнуться с cyborg/run.py в sys.path) — не дублируем.
"""
import importlib.util
import os
import sys

from organs_vendored import scrub_secrets

_IDEA = "M:/projects/kiborg/idea_engine"
if _IDEA not in sys.path:
    sys.path.insert(0, _IDEA)


def _load_ie_run():
    spec = importlib.util.spec_from_file_location("ie_run", os.path.join(_IDEA, "run.py"))
    m = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(m)
    return m


def _scrub_nudge(nudge):
    """Заредактить креды в тексте подсказки перед записью (title/why — как у идей)."""
    clean = dict(nudge)
    for f in ("title", "why"):
        if isinstance(clean.get(f), str):
            clean[f] = scrub_secrets.scrub_text(clean[f])
    return clean


def run(inputs, env):
    inp = inputs or {}
    nudge = inp.get("nudge")
    # пусто (None / {} / не dict) — доставлять нечего, no-op (диск не трогаем)
    if not isinstance(nudge, dict) or not nudge:
        return {"delivered": 0, "inbox": None, "lane": "B"}
    safe = _scrub_nudge(nudge)              # ветка «доделай» больше НЕ минует вычистку
    ie = _load_ie_run()
    from store import Store                  # idea_engine/store.py
    store = Store(ie.STATE, cap=ie.CFG["cap"])
    # ДОРОЖКА B: отдельный слот, не конкурирует с новыми идеями за потолок 3.
    store.set_finish(safe, store.data.get("cursor", 0))
    store.save()
    ie._write_inbox(store)
    return {"delivered": 1, "inbox": ie.INBOX, "lane": "B"}


if __name__ == "__main__":
    # смоук БЕЗ реальной записи (не мусорить в живой инбокс) — только вычистка
    demo = {"title": "Доделать: panelofprojects",
            "why": "починить путь; токен 12345678:AAHrealbottoken0123456789ABCDEFGHIJKL"}
    safe = _scrub_nudge(demo)
    leaked = "12345678:AAH" in safe["why"]
    print("scrubbed why:", safe["why"])
    print("SMOKE", "OK" if not leaked else "FAIL")
